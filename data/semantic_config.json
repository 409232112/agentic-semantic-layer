  "scenarios": [
    {
      "code": "1",
      "name": "电商跨库客户与订单消费分析",
      "description": "",
      "global_rules": "客户档案和画像级别数据存储在 CRM 系统（运行在 **PostgreSQL** 上，便于处理半结构化数据和复杂画像关系），而高频订单交易明细存储在交易系统（运行在 **MySQL** 上，便于高并发事务写入）。",
      "catalogs": [
        "postgresql",
        "mysql"
      ],
      "tables": [
        "postgresql.public.crm_customers",
        "mysql.agentic.mall_orders"
      ],
      "table_overrides": {
        "postgresql.public.crm_customers": "存储客户基础信息与客户等级",
        "mysql.agentic.mall_orders": "存储订单金额、支付状态及下单时间"
      },
      "field_overrides": {
        "postgresql.public.crm_customers": {
          "name": {
            "description": "客户姓名"
          },
          "email": {
            "description": "客户邮箱"
          },
          "level": {
            "description": "客户等级，'Bronze', 'Silver', 'Gold', 'Platinum'"
          },
          "register_date": {
            "description": "注册日期"
          }
        },
        "mysql.agentic.mall_orders": {
          "order_id": {
            "description": "订单ID"
          },
          "customer_id": {
            "description": "用户ID,关联crm_customers中的ID"
          },
          "total_amount": {
            "description": "消费金额"
          },
          "order_status": {
            "description": "订单状态，COMPLETED已完成，PENDING处理中"
          },
          "created_at": {
            "description": "创建时间"
          }
        }
      }
    },
    {
      "code": "2",
      "name": "HR 绩效评级与财务薪酬匹配分析",
      "description": "",
      "global_rules": "员工基本档案和季度绩效考核等级存储在 HR 人事管理数据库（运行在 **MySQL**），而敏感的工资发放明细和年终奖明细存储在财务系统（运行在 **PostgreSQL**，以确保数据安全）。",
      "catalogs": [
        "postgresql",
        "mysql"
      ],
      "tables": [
        "postgresql.public.fin_payroll",
        "mysql.agentic.hr_employees"
      ],
      "table_overrides": {
        "postgresql.public.fin_payroll": "存储月基本薪资、奖金",
        "mysql.agentic.hr_employees": "存储员工姓名、部门、考评等级"
      },
      "field_overrides": {
        "postgresql.public.fin_payroll": {
          "emp_id": {
            "description": "员工ID,hr_employees中的ID"
          },
          "base_salary": {
            "description": "基础工资"
          },
          "bonus": {
            "description": "奖金"
          },
          "pay_date": {
            "description": "工资日期"
          }
        },
        "mysql.agentic.hr_employees": {
          "name": {
            "description": "员工姓名"
          },
          "department": {
            "description": "所属部门"
          },
          "performance_rating": {
            "description": "绩效等级，A,B,C"
          }
        }
      }
    },
    {
      "code": "3",
      "name": "IoT 设备台账与监控指标告警分析",
      "description": "",
      "global_rules": "物联网设备的基本出厂台账（设备型号、部署地点、厂商等）存放在 **MySQL** 资产管理表中；而设备采集的实时遥测温度和湿度指标通过流处理引擎快速汇入 **PostgreSQL**（时间序列存储）。",
      "catalogs": [
        "postgresql",
        "mysql"
      ],
      "tables": [
        "postgresql.public.device_telemetry",
        "mysql.agentic.asset_registry"
      ],
      "table_overrides": {
        "postgresql.public.device_telemetry": "温度、湿度等指标流",
        "mysql.agentic.asset_registry": "设备台账 and 部署地点"
      },
      "field_overrides": {
        "postgresql.public.device_telemetry": {
          "device_sn": {
            "description": "设备SN码"
          },
          "temperature": {
            "description": "温度"
          },
          "humidity": {
            "description": "湿度"
          },
          "recorded_at": {
            "description": "记录时间"
          }
        },
        "mysql.agentic.asset_registry": {
          "device_sn": {
            "description": "设备SN码"
          },
          "device_type": {
            "description": "设备类型，'Sensor', 'Gateway', 'Controller'"
          },
          "installation_site": {
            "description": "设备位置"
          },
          "status": {
            "description": "设备状态，ACTIVE，MAINTENANCE"
          }
        }
      }
    }
  ]
}